# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=webtokobajuu

# Midtrans Payment Gateway
# Get these from https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=YOUR_SERVER_KEY_HERE
MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY_HERE
NODE_ENV=development

# Payment Redirect URLs (optional, defaults to localhost)
PAYMENT_REDIRECT_URL=http://localhost:3000/payment-status.html

# Optional Marketplace API Keys
TOKOPEDIA_API_KEY=
SHOPEE_API_KEY=

# Server Port
PORT=3000
